{
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "pi-acp": {
      "default_model": "ollama/deepseek-v4-pro:cloud",
      "type": "registry",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "buffer_font_family": "CaskaydiaMono Nerd Font",
  "buffer_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "relative_line_numbers": "enabled",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "show_edit_predictions": false,
  "languages": {
    "CSharp": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "dotnet",
          "arguments": ["csharpier", "format"],
        },
      },
    },
  },
}
