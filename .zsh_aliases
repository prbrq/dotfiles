# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ls (eza if available, else portable color ls)
if command -v eza >/dev/null 2>&1; then
  alias ls='eza'
  alias ll='eza -lh'
  alias la='eza -lah'
  alias lt='eza --tree --level=2'
else
  if ls --color=auto / >/dev/null 2>&1; then
    alias ls='ls --color=auto'
  else
    alias ls='ls -G'
  fi
  alias ll='ls -lh'
  alias la='ls -lAh'
fi

# Safety
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'
alias mkdir='mkdir -p'
